// NyayVakil – Prisma Schema
// Database: PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  advocate
  junior
  clerk
  admin
}

enum ClientType {
  individual
  company
  family
  organization
}

enum MatterStatus {
  active
  pending
  disposed
  on_hold
  closed
}

enum MatterPriority {
  high
  medium
  low
}

enum CourtLevel {
  supreme_court
  high_court
  district_court
  sessions_court
  magistrate_court
  family_court
  consumer_court
  tribunal
  other
}

enum HearingStatus {
  upcoming
  attended
  adjourned
  completed
  missed
}

enum FeeStatus {
  paid
  partially_paid
  overdue
  not_started
}

enum PaymentMethod {
  cash
  bank_transfer
  cheque
  upi
  other
}

enum ExpenseType {
  court_fee
  clerk_expense
  photocopy
  typing
  travel
  affidavit
  filing
  stamp
  miscellaneous
}

enum DocumentCategory {
  vakalatnama
  affidavit
  notice
  petition
  written_statement
  evidence
  receipt
  invoice
  id_proof
  court_order
  miscellaneous
}

enum TaskStatus {
  pending
  in_progress
  completed
  cancelled
}

enum TaskPriority {
  high
  medium
  low
}

enum ReminderType {
  hearing
  payment
  document
  follow_up
  general
}

enum ReminderStatus {
  pending
  sent
  acknowledged
  cancelled
}

enum ReminderChannel {
  whatsapp
  sms
  email
  internal
}

enum TimelineEventType {
  created
  hearing_added
  payment_logged
  expense_added
  document_uploaded
  reminder_created
  task_completed
  status_changed
  note_added
  hearing_completed
}

enum SubscriptionPlan {
  free
  solo
  chamber
  firm
}

enum SubscriptionStatus {
  trialing
  active
  expired
  cancelled
  suspended
}

// ─────────────────────────────────────────────
// FIRM
// ─────────────────────────────────────────────

model Firm {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  clients           Client[]
  matters           Matter[]
  hearings          Hearing[]
  feeEntries        FeeEntry[]
  payments          Payment[]
  expenses          Expense[]
  documents         Document[]
  tasks             Task[]
  reminders         Reminder[]
  timelineEntries   TimelineEntry[]
  reminderTemplates ReminderTemplate[]
  officeSettings    OfficeSettings?
  subscription      Subscription?

  @@map("firms")
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  passwordHash     String
  phone            String
  role             UserRole @default(advocate)
  avatar           String?
  barCouncilNumber String?
  specialization   String[]
  chamberName      String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  firmId String

  firm            Firm            @relation(fields: [firmId], references: [id], onDelete: Cascade)
  sessions        Session[]
  matters         Matter[]        @relation("CreatedByUser")
  assignedMatters Matter[]        @relation("AssignedJunior")
  clerkMatters    Matter[]        @relation("AssignedClerk")
  assignedTasks   Task[]          @relation("AssignedToUser")
  createdTasks    Task[]          @relation("AssignedByUser")
  timeline        TimelineEntry[]

  @@map("users")
}

// ─────────────────────────────────────────────
// SESSION
// ─────────────────────────────────────────────

model Session {
  id         String   @id @default(cuid())
  token      String   @unique
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  userId String
  firmId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─────────────────────────────────────────────
// SUBSCRIPTION
// ─────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  plan                 SubscriptionPlan   @default(free)
  status               SubscriptionStatus @default(trialing)
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  razorpaySubId        String?
  razorpayCustomerId   String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  firmId String @unique

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─────────────────────────────────────────────
// CLIENT
// ─────────────────────────────────────────────

model Client {
  id              String     @id @default(cuid())
  name            String
  mobile          String
  alternateMobile String?
  email           String?
  address         String?
  city            String?
  state           String?
  pincode         String?
  clientType      ClientType @default(individual)
  notes           String?
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  firmId String

  firm      Firm            @relation(fields: [firmId], references: [id], onDelete: Cascade)
  matters   Matter[]
  feeEntries FeeEntry[]
  payments  Payment[]
  expenses  Expense[]
  documents Document[]
  tasks     Task[]
  reminders Reminder[]
  timeline  TimelineEntry[]

  @@map("clients")
}

// ─────────────────────────────────────────────
// MATTER (CASE)
// ─────────────────────────────────────────────

model Matter {
  id               String         @id @default(cuid())
  matterTitle      String
  caseNumber       String?
  cnrNumber        String?
  caseType         String
  courtName        String
  courtLevel       CourtLevel     @default(district_court)
  caseStage        String?
  filingDate       DateTime?
  nextHearingDate  DateTime?
  oppositeParty    String?
  oppositeAdvocate String?
  advocateOnRecord String?
  status           MatterStatus   @default(active)
  priority         MatterPriority @default(medium)
  judgeName        String?
  policeStation    String?
  actSection       String?
  notes            String?
  totalFeeAgreed   Float          @default(0)
  totalFeePaid     Float          @default(0)
  totalExpenses    Float          @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  firmId           String
  clientId         String
  createdBy        String
  assignedJuniorId String?
  assignedClerkId  String?

  firm           Firm            @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client         Client          @relation(fields: [clientId], references: [id])
  creator        User            @relation("CreatedByUser", fields: [createdBy], references: [id])
  assignedJunior User?           @relation("AssignedJunior", fields: [assignedJuniorId], references: [id])
  assignedClerk  User?           @relation("AssignedClerk", fields: [assignedClerkId], references: [id])
  hearings       Hearing[]
  feeEntries     FeeEntry[]
  payments       Payment[]
  expenses       Expense[]
  documents      Document[]
  tasks          Task[]
  reminders      Reminder[]
  timeline       TimelineEntry[]

  @@map("matters")
}

// ─────────────────────────────────────────────
// HEARING
// ─────────────────────────────────────────────

model Hearing {
  id               String        @id @default(cuid())
  date             DateTime
  time             String?
  purpose          String?
  notes            String?
  nextAction       String?
  nextHearingDate  DateTime?
  assignedTo       String?
  appearanceStatus String?
  status           HearingStatus @default(upcoming)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  firmId   String
  matterId String

  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@map("hearings")
}

// ─────────────────────────────────────────────
// FEE ENTRY
// ─────────────────────────────────────────────

model FeeEntry {
  id             String    @id @default(cuid())
  description    String
  totalAmount    Float
  receivedAmount Float     @default(0)
  pendingAmount  Float
  dueDate        DateTime?
  status         FeeStatus @default(not_started)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  firmId   String
  matterId String
  clientId String

  firm     Firm      @relation(fields: [firmId], references: [id], onDelete: Cascade)
  matter   Matter    @relation(fields: [matterId], references: [id], onDelete: Cascade)
  client   Client    @relation(fields: [clientId], references: [id])
  payments Payment[]

  @@map("fee_entries")
}

// ─────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────

model Payment {
  id              String        @id @default(cuid())
  amount          Float
  paymentMethod   PaymentMethod @default(cash)
  paymentDate     DateTime
  referenceNumber String?
  receiptNumber   String?
  notes           String?
  createdAt       DateTime      @default(now())

  firmId     String
  feeEntryId String
  matterId   String
  clientId   String

  firm     Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)
  feeEntry FeeEntry @relation(fields: [feeEntryId], references: [id], onDelete: Cascade)
  matter   Matter   @relation(fields: [matterId], references: [id])
  client   Client   @relation(fields: [clientId], references: [id])

  @@map("payments")
}

// ─────────────────────────────────────────────
// EXPENSE
// ─────────────────────────────────────────────

model Expense {
  id            String      @id @default(cuid())
  date          DateTime
  expenseType   ExpenseType
  description   String
  amount        Float
  paidBy        String
  isRecoverable Boolean     @default(false)
  isRecovered   Boolean     @default(false)
  notes         String?
  receiptUrl    String?
  createdAt     DateTime    @default(now())

  firmId   String
  matterId String?
  clientId String?

  firm   Firm    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  matter Matter? @relation(fields: [matterId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])

  @@map("expenses")
}

// ─────────────────────────────────────────────
// DOCUMENT
// ─────────────────────────────────────────────

model Document {
  id          String           @id @default(cuid())
  name        String
  category    DocumentCategory @default(miscellaneous)
  fileType    String
  fileSize    String
  fileUrl     String?
  description String?
  uploadedBy  String
  tags        String[]
  uploadedAt  DateTime         @default(now())

  firmId   String
  matterId String?
  clientId String?

  firm   Firm    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  matter Matter? @relation(fields: [matterId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])

  @@map("documents")
}

// ─────────────────────────────────────────────
// TASK
// ─────────────────────────────────────────────

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  priority    TaskPriority @default(medium)
  status      TaskStatus   @default(pending)
  notes       String?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  firmId     String
  assignedTo String
  assignedBy String
  matterId   String?
  clientId   String?

  firm     Firm    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  assignee User    @relation("AssignedToUser", fields: [assignedTo], references: [id])
  assigner User    @relation("AssignedByUser", fields: [assignedBy], references: [id])
  matter   Matter? @relation(fields: [matterId], references: [id])
  client   Client? @relation(fields: [clientId], references: [id])

  @@map("tasks")
}

// ─────────────────────────────────────────────
// REMINDER
// ─────────────────────────────────────────────

model Reminder {
  id          String          @id @default(cuid())
  type        ReminderType
  title       String
  message     String
  scheduledAt DateTime
  status      ReminderStatus  @default(pending)
  sentAt      DateTime?
  channel     ReminderChannel @default(internal)
  createdAt   DateTime        @default(now())

  firmId   String
  clientId String?
  matterId String?

  firm   Firm    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id])
  matter Matter? @relation(fields: [matterId], references: [id])

  @@map("reminders")
}

// ─────────────────────────────────────────────
// TIMELINE
// ─────────────────────────────────────────────

model TimelineEntry {
  id          String            @id @default(cuid())
  entityType  String
  entityId    String
  type        TimelineEventType
  title       String
  description String?
  userName    String
  createdAt   DateTime          @default(now())

  firmId   String
  userId   String
  matterId String?
  clientId String?

  firm   Firm    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id])
  matter Matter? @relation(fields: [matterId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])

  @@map("timeline_entries")
}

// ─────────────────────────────────────────────
// REMINDER TEMPLATE
// ─────────────────────────────────────────────

model ReminderTemplate {
  id       String       @id @default(cuid())
  name     String
  type     ReminderType
  template String

  firmId String

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@map("reminder_templates")
}

// ─────────────────────────────────────────────
// OFFICE SETTINGS
// ─────────────────────────────────────────────

model OfficeSettings {
  id               String   @id @default(cuid())
  officeName       String
  advocateName     String
  barCouncilNumber String
  address          String
  city             String
  state            String
  phone            String
  email            String
  website          String?
  gstin            String?
  panNumber        String?
  logo             String?
  updatedAt        DateTime @updatedAt

  firmId String @unique

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@map("office_settings")
}

// ─────────────────────────────────────────────
// COURT REGISTRY (shared master data)
// ─────────────────────────────────────────────

model CourtRegistry {
  id       String     @id @default(cuid())
  name     String
  level    CourtLevel
  location String
  state    String

  @@map("court_registry")
}

// ─────────────────────────────────────────────
// CASE TYPES (per firm, customizable)
// ─────────────────────────────────────────────

model CaseType {
  id     String @id @default(cuid())
  name   String
  firmId String

  @@map("case_types")
}
